# App
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://quaypanel:quaypanel@localhost:5432/quaypanel

# Redis
# Option A: put the password in the URL — redis://:yourpassword@localhost:6379
# Option B: leave URL without auth and set REDIS_PASSWORD
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Seed admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Admin

# Default brand / currency
DEFAULT_CURRENCY=USD
DEFAULT_BRAND_NAME=QuayPanel

# SMTP (optional in development)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Built-in gateway secrets (can also be set in admin UI)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Pterodactyl (optional — can also set in Admin → Settings)
PTERODACTYL_URL=
PTERODACTYL_API_KEY=
